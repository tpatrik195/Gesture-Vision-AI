FROM node:18-alpine AS build
WORKDIR /app/client_frontend
COPY client_frontend/package.json client_frontend/package-lock.json ./
RUN npm ci
COPY client_frontend ./
RUN npm run build

FROM nginx:1.27-alpine
COPY docker/nginx.prod.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/client_frontend/build /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
